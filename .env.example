# Weather
SKILL_WEATHER_PROVIDER=meteoam
SKILL_WEATHER_EXTRACTOR_ORDER=jina,tavily
# Optional. Override built-in URL-template providers or define custom ones.
# SKILL_WEATHER_CUSTOM_METEOAM_URL=https://www.meteoam.it/it/meteo-citta/{city}
# SKILL_WEATHER_CUSTOM_3BMETEO_URL=https://www.3bmeteo.com/meteo/{city}
# SKILL_WEATHER_CUSTOM_EXAMPLE_URL=https://example.com/weather/{city}
# Optional. Override extractor order for a specific provider.
# SKILL_WEATHER_CUSTOM_METEOAM_EXTRACTORS=jina,tavily
# SKILL_WEATHER_CUSTOM_EXAMPLE_EXTRACTORS=tavily,jina
# Shared credentials used by this skill's extractors.
# JINA_API_KEY=
# TAVILY_API_KEY=
